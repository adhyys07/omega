# Copy to .env and fill in. The server reads these via --env-file=.env.

# ---- Airtable (data store) ----
# Personal access token scoped to the base, with data.records:read + data.records:write.
AIRTABLE_PAT=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ---- Sessions ----
# Signs the session + OAuth-state cookies. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Server ----
PORT=3000
# Allowed browser origin for CORS (the frontend dev server).
CORS_ORIGIN=http://localhost:5173
# Where the user is redirected after a successful login.
FRONTEND_URL=http://localhost:5173
# Set to "production" to mark cookies Secure (HTTPS-only).
# NODE_ENV=production

# ---- Sign in with Hack Club (OIDC, auth.hackclub.com) ----
HC_CLIENT_ID=
HC_CLIENT_SECRET=
# Must exactly match the redirect URI registered on the HCA app.
HC_REDIRECT_URI=http://localhost:3000/api/auth/callback

#Hackatime OAuth credentials for getting Hearbeats and hackatime projects.
HACKATIME_CLIENT_ID = 
HACKATIME_CLIENT_SECRET = 
HACKATIME_REDIRECT_URI=

#To store screenshots and demo videos
CDN_API_KEY=

# ---- Slack review workflow ----
# Bot token (xoxb-…) with scopes: chat:write, im:write. Interactivity must be
# enabled with the request URL pointed at /api/slack/interactivity.
SLACK_BOT_TOKEN=
# Channel id (Cxxxxxxxx) where submission review cards are posted.
SLACK_REVIEW_CHANNEL=
# Signing secret from the Slack app's Basic Information page; verifies requests.
SLACK_SIGNING_SECRET=
# Reviewers are drawn from ADMIN_SLACK_IDS below.

#Github API token to fetch readmes and open source repos for submissions. Needs repo scope.
GITHUB_TOKEN=

# ---- Admin allow-lists (comma-separated; a match on either grants superuser) ----
ADMIN_SLACK_IDS=
ADMIN_EMAILS=

# ---- Hack Club AI (optional) ----
# Base URL for the Hack Club AI API. Leave blank to disable.
HC_AI_BASE_URL=https://ai.hackclub.com/api/v1
HC_AI_KEY=
HC_AI_MODEL=